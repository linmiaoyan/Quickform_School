###############################################
# QuickForm example.env (PostgreSQL-only)
#
# 用法：复制为仓库根目录下的 .env（与 app.py 同级），按环境修改后启动。
# “高亮”说明：以下用 >>> 与 === 框出的区块为部署后一般需要核对/填写的项。
###############################################

###############################################################################
# >>> [必配] 密钥与数据库 — 不填则无法正常运行 <<<
###############################################################################
SECRET_KEY=change-me-to-a-strong-random-value

# 站点版本号（浏览器标题栏、页脚展示；可与发布日期一致，例如 2026.05.02）
APP_VERSION=1.0.0

# 默认管理员账号（首次启动自动创建/确保存在）
# 建议部署后立刻登录修改密码；如不想暴露默认密码，可在首次启动前先改这里。
DEFAULT_ADMIN_USERNAME=wst
DEFAULT_ADMIN_PASSWORD=quickform

# 推荐：完整 SQLAlchemy 连接串（psycopg v3）
DATABASE_URL=postgresql+psycopg://quickform:你的数据库密码@127.0.0.1:5432/quickform

# 备选：未设置 DATABASE_URL 时使用以下分项
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_USER=quickform
# POSTGRES_PASSWORD=你的数据库密码
# POSTGRES_DB=quickform


###############################################################################
# >>> [必配·生产] 对外地址与 Cookie — 反代/HTTPS 或邮件/链接错误时重点检查 <<<
###############################################################################
# 反向代理/HTTPS：固定对外站点根 URL，避免页面生成 http 接口导致 Mixed Content
PUBLIC_BASE_URL=https://你的域名或网关地址
PREFERRED_URL_SCHEME=https
SESSION_COOKIE_SECURE=true
REMEMBER_COOKIE_SECURE=true

# 纯内网 HTTP、无 TLS 时可改为（按实际选择一种场景，不要混用未理解的组合）：
# PUBLIC_BASE_URL=http://内网IP或主机名:端口
# PREFERRED_URL_SCHEME=http
# SESSION_COOKIE_SECURE=false
# REMEMBER_COOKIE_SECURE=false


###############################################################################
# >>> [必配·部署方式] 监听与 Waitress 线程 — 与是否走 Nginx、绑定网卡有关 <<<
###############################################################################
# 无反代、需本机局域网访问时通常用 0.0.0.0 + 对外端口；前面有 Nginx 时常为 127.0.0.1 + 后端端口
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
WAITRESS_THREADS=8


###############################################################################
# >>> [必配·业务] 邮件 — 不配则验证码、通知等发信会失败 <<<
###############################################################################
MAIL_SERVER=smtp.163.com
# 常见：587 + STARTTLS（与下面 MAIL_USE_TLS 搭配）
#MAIL_PORT=587
# 若使用 465，请查阅邮箱厂商说明（部分环境需 SSL 而非 STARTTLS）
MAIL_PORT=465
MAIL_USE_TLS=True
MAIL_USERNAME=你的发信邮箱@163.com
MAIL_PASSWORD=你的SMTP授权码
MAIL_DEFAULT_SENDER=你的发信邮箱@163.com


###############################################################################
# >>> [建议] 硅基流动 / 一键内测 — 用户未在个人中心填 API 时使用 <<<
###############################################################################
CHAT_SERVER_API_TOKEN=填写硅基流动_API_Token


###############################################################################
# >>> [可选] API 读缓存 — 一般保持默认即可 <<<
###############################################################################
API_READ_CACHE_TTL=10
API_READ_CACHE_MAX_KEYS=1000


###############################################################################
# [可选·已对齐程序默认] 批量删除 — 减轻大表清空时的锁等待；一般不改即可直接使用
###############################################################################
DB_DELETE_BATCH_SIZE=200
DB_DELETE_MAX_RETRIES=3
DB_DELETE_RETRY_SLEEP=0.3
