###############################################
# QuickForm example.env (PostgreSQL-only)
#
# Usage:
# - Copy to .env in the repo root (same folder as app.py)
# - Fill in values, then start: python app.py
###############################################

# REQUIRED: must be a strong random string
SECRET_KEY=change-me-to-a-strong-random-value

# Preferred: full SQLAlchemy URL (psycopg v3)
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://quickform:change-me@127.0.0.1:5432/quickform

# Alternative: split variables (used only when DATABASE_URL is not set)
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_USER=quickform
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=quickform

# Optional: local/dev over HTTP (behind reverse proxy / no TLS)
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SECURE=false
FLASK_HOST=0.0.0.0
FLASK_PORT=80
FLASK_DEBUG=false
